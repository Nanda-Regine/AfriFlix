{
  "name": "AfriFlix",
  "short_name": "AfriFlix",
  "description": "African creativity has finally found its home. Film, music, dance, poetry, writing and more from all 54 African nations.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#0a0a0a",
  "theme_color": "#C4622D",
  "orientation": "any",
  "lang": "en-ZA",
  "dir": "ltr",
  "categories": ["entertainment", "music", "social"],
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/home.jpg",
      "sizes": "1280x720",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "AfriFlix Home"
    }
  ],
  "share_target": {
    "action": "/dashboard/upload",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "files": [
        {
          "name": "file",
          "accept": ["video/*", "audio/*", "image/*"]
        }
      ]
    }
  },
  "related_applications": [],
  "prefer_related_applications": false
}
